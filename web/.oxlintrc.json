{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "env": {
    "es2024": true
  },
  "ignorePatterns": ["public_html/"],
  "rules": {
    "no-underscore-dangle": "off",
    "unicorn/consistent-function-scoping": "off"
  },
  "overrides": [
    {
      "files": ["*.js", "*.mjs"],
      "env": { "node": true }
    },
    {
      "files": ["src/*.js"],
      "env": { "browser": true }
    }
  ]
}
